# Copy to .env. None of this is required for the core "aha" (checkpoint 2 uses the fake token below
# against a public header-reflector). Fill the optional slots only if you brought real keys.

# --- The workshop's fake credential (this is the whole point: the agent never sees the real one) ---
# Any non-secret string works. The broker injects THIS value; you'll watch it appear server-side.
WORKSHOP_TOKEN=wsk_live_this_is_not_a_real_secret_0000

# --- Broker connection (defaults are correct for the local setup; override only if you must) ---
AGENT_VAULT_ADDR=http://localhost:14321
AGENT_VAULT_VAULT=workshop

# --- OPTIONAL: real services, only if you want to broker something live ---
# GitHub fine-grained PAT (read-only is fine):
# GITHUB_TOKEN=github_pat_...
# Stripe TEST-mode secret key (never a live key):
# STRIPE_KEY=sk_test_...
